<?xml version="1.0"?>
<ruleset name="MP Service Suite">
    <description>WordPress Coding Standards — 3 pluginy MP + wspolna biblioteka.</description>

    <file>mp-service-intake</file>
    <file>mp-warranty-registry</file>
    <file>mp-workflow-automator</file>
    <file>lib</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/testy/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/includes/Common/*</exclude-pattern><!-- kopie generowane przez build z lib/mp-common -->

    <rule ref="WordPress">
        <!-- natywny autoloader PSR-4-style (kontrakt: zero Composera w runtime) => pliki klas Nazwa.php, nie class-nazwa.php -->
        <exclude name="WordPress.Files.FileName"/>
    </rule>

    <!-- zgodnosc PHP: podloga 8.1 ze spec -->
    <config name="testVersion" value="8.1-"/>
    <rule ref="PHPCompatibilityWP"/>

    <config name="minimum_wp_version" value="6.9"/>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <!-- prefiks "mp_" jest KONTRAKTEM ze specyfikacji klienta (tabele wp_mp_*, hooki mp_*);
             sniff dalej WYMUSZA prefiksowanie wszystkich globali — wylaczamy tylko skarge na dlugosc -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.ShortPrefixPassed"/>
        <properties>
            <property name="prefixes" type="array">
                <element value="mp_"/>
                <element value="MP_"/>
                <element value="MP"/>
            </property>
        </properties>
    </rule>

    <!-- 3 text-domainy (po jednym per plugin); doprecyzowanie per-plugin przy realnych stringach i18n (D3+) -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="mp-service-intake"/>
                <element value="mp-warranty-registry"/>
                <element value="mp-workflow-automator"/>
            </property>
        </properties>
    </rule>

    <arg value="sp"/>
    <arg name="extensions" value="php"/>
    <arg name="basepath" value="."/>
</ruleset>
