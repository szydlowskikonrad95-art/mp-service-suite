{
    "name": "mp/mp-service-suite",
    "description": "System serwisowy MP — narzedzia deweloperskie (Composer WYLACZNIE dev; pluginy dzialaja bez Composera).",
    "license": "GPL-2.0-or-later",
    "type": "project",
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "php-stubs/wordpress-stubs": "~6.9.0",
        "php-stubs/wp-cli-stubs": "^2.11",
        "phpstan/phpstan-deprecation-rules": "^1.2",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^10"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "find mp-service-intake mp-warranty-registry mp-workflow-automator lib -name '*.php' -print0 | xargs -0 -n1 php -l",
        "phpcs": "phpcs",
        "phpstan": "phpstan analyse --no-progress --memory-limit=1G",
        "test": "phpunit",
        "tabele": "php build/lint-cudze-tabele.php"
    }
}
